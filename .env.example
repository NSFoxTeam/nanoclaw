# NanoClaw Configuration
# Copy to .env and fill in your values

# --- Core ---
ASSISTANT_NAME=Vlad

# --- Auth (one required) ---
# CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# --- GitHub Webhook ---
# HMAC secret for validating GitHub org webhooks (X-Hub-Signature-256)
GITHUB_WEBHOOK_SECRET=
# Port for the webhook HTTP server (default: 18789)
GITHUB_WEBHOOK_PORT=18789
# GitHub bot login for anti-loop detection (default: vlad-nsfox)
GITHUB_BOT_LOGIN=vlad-nsfox
# Group folder that receives webhook messages (set to enable auto-registration)
GITHUB_WEBHOOK_GROUP_FOLDER=github

# --- API compatibility (dispatch.yml fallback) ---
# Bearer token for POST /hooks/agent
API_KEY=

# --- GitHub CLI inside containers ---
# PAT for `gh auth` (passed to containers as GH_TOKEN)
GH_TOKEN=
